        "query": "CREATE TABLE IF NOT EXISTS conversas_brinka ( id SERIAL PRIMARY KEY, numero VARCHAR(100) NOT NULL UNIQUE, nome VARCHAR(100), ultimo_contato TIMESTAMP DEFAULT NOW(), total_msgs INTEGER DEFAULT 1 ); INSERT INTO conversas_brinka (numero, nome) VALUES ('{{ $('Webhook — Receber Msg WA').item.json.body.phone }}', '{{ $('Webhook — Receber Msg WA').item.json.body.senderName }}') ON CONFLICT (numero) DO NOTHING; UPDATE conversas_brinka SET ultimo_contato = NOW(), total_msgs = total_msgs + 1, nome = '{{ $('Webhook — Receber Msg WA').item.json.body.senderName }}' WHERE numero = '{{ $('Webhook — Receber Msg WA').item.json.body.phone }}'; CREATE TABLE IF NOT EXISTS mensagens_brinka ( id SERIAL PRIMARY KEY, numero VARCHAR(100), nome VARCHAR(100), direcao VARCHAR(10), conteudo TEXT, criado_em TIMESTAMP DEFAULT NOW() ); INSERT INTO mensagens_brinka (numero, nome, direcao, conteudo) VALUES ('{{ $('Webhook — Receber Msg WA').item.json.body.phone }}', '{{ $('Webhook — Receber Msg WA').item.json.body.senderName }}', 'entrada', '{{ $('Webhook — Receber Msg WA').item.json.body.text.message }}');",
        "options": {}
