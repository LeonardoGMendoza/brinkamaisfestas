      "id": "bm-if-fechar",
      "name": "Verificar Fechamento Pedido",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1580, 1120]
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.output;\nconst blockMatch = text.match(/\\[FECHAR_PEDIDO\\]([\\s\\S]*?)\\[\\/FECHAR_PEDIDO\\]/);\nlet brinquedo = '', data = '', endereco = '', criancas = 0, obs = '';\n\nif (blockMatch) {\n  const block = blockMatch[1];\n  const extract = (label) => {\n    const regex = new RegExp(`${label}:\\s*(.*)`);\n    const m = block.match(regex);\n    return m ? m[1].trim() : '';\n  };\n  brinquedo = extract('Brinquedo');\n  data = extract('Data');\n  endereco = extract('Endereço');\n  criancas = parseInt(extract('Criancas')) || 0;\n  obs = extract('Obs');\n}\n\nlet dataSql = 'NULL';\nif (data.match(/^\\d{4}-\\d{2}-\\d{2}$/)) {\n  dataSql = `'${data}'`;\n}\n\nreturn [{\n  json: {\n    brinquedo, dataSql, endereco, criancas, obs,\n    cliente_nome: $('Webhook — Receber Msg WA').item.json.body.senderName,\n    cliente_tel: $('Webhook — Receber Msg WA').item.json.body.phone\n  }\n}];"
      },
